<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Servo.Sharp.Demo.Core.App"
             Name="AvaServo"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Servo.Sharp.Avalonia/Themes/Fluent/Fluent.xaml" />
    </Application.Styles>
</Application>
