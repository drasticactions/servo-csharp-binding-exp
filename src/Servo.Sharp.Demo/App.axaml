<core:App xmlns="https://github.com/avaloniaui"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:core="clr-namespace:Servo.Sharp.Demo.Core;assembly=Servo.Sharp.Demo.Core"
          x:Class="Servo.Sharp.Demo.App"
          Name="AvaServo"
          RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Servo.Sharp.Avalonia/Themes/Fluent/Fluent.xaml" />
    </Application.Styles>
</core:App>