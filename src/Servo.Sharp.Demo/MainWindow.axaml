<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:servo="using:Servo.Sharp.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Servo.Sharp.Demo.MainWindow"
        Title="Servo C# Demo"
        Width="1024" Height="768">
    <DockPanel>
        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" Margin="4">
            <Button x:Name="BackButton" Grid.Column="0" Content="&#x2190;" Width="32"
                    IsEnabled="False" Margin="0,0,2,0" />
            <Button x:Name="ForwardButton" Grid.Column="1" Content="&#x2192;" Width="32"
                    IsEnabled="False" Margin="0,0,2,0" />
            <Button x:Name="ReloadButton" Grid.Column="2" Content="&#x21BB;" Width="32"
                    Margin="0,0,4,0" />
            <TextBox x:Name="UrlBar" Grid.Column="3"
                     PlaceholderText="Enter URL and press Enter..."
                     Text="https://servo.org" />
            <Button x:Name="GoButton" Grid.Column="4"
                    Content="Go" Margin="4,0,0,0" />
            <Button x:Name="ZoomOutButton" Grid.Column="5" Content="-" Width="28" Margin="4,0,0,0" />
            <Button x:Name="ZoomInButton" Grid.Column="6" Content="+" Width="28" Margin="2,0,0,0" />
            <Button x:Name="ScreenshotButton" Grid.Column="7" Content="&#x1F4F7;" Width="32" Margin="2,0,0,0"
                    ToolTip.Tip="Take screenshot" />
            <Button x:Name="BackendButton" Grid.Column="8" Content="HW" Width="36" Margin="2,0,0,0"
                    ToolTip.Tip="Toggle hardware/software rendering" />
        </Grid>

        <!-- JS console bar -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="4,2,4,0">
            <TextBlock Grid.Column="0" Text="JS:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="JsInput" Grid.Column="1" PlaceholderText="JavaScript expression..." />
            <Button x:Name="JsRunButton" Grid.Column="2" Content="Run" Margin="4,0,0,0" />
        </Grid>

        <!-- Status bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
            <TextBlock x:Name="StatusText" Text="Ready" />
        </StackPanel>

        <!-- WebView container — control is swapped on backend change -->
        <Panel x:Name="WebViewContainer">
            <servo:ServoWebViewControl x:Name="WebView" />
        </Panel>
    </DockPanel>
</Window>
