<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Servo.Sharp.Demo"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Servo.Sharp.Demo.MainWindow"
        Title="Servo C# Demo"
        Width="1024" Height="768">
    <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,Auto,*" Margin="4,4,4,2">
            <Button x:Name="BackButton" Grid.Column="0" Content="&#x25C1;" Width="32" Height="28"
                    IsEnabled="False" Margin="0,0,2,0" FontSize="14"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            <Button x:Name="ForwardButton" Grid.Column="1" Content="&#x25B7;" Width="32" Height="28"
                    IsEnabled="False" Margin="0,0,2,0" FontSize="14"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            <Button x:Name="ReloadButton" Grid.Column="2" Content="&#x21BB;" Width="32" Height="28"
                    Margin="0,0,4,0" FontSize="14"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            <TextBox x:Name="UrlBar" Grid.Column="3"
                     VerticalContentAlignment="Center" Height="28"
                     FontSize="13"
                     Text="https://servo.org" />
        </Grid>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="4,2,4,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <local:DragTabPanel x:Name="TabStrip" />
                </ScrollViewer>
                <Button x:Name="NewTabButton" Grid.Column="1"
                        Content="+" Width="28" Height="24"
                        FontSize="16" Padding="0"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Margin="4,0,0,0"
                        ToolTip.Tip="New tab" />
                <Button x:Name="NewWindowButton" Grid.Column="2"
                        Content="&#x229E;" Width="28" Height="24"
                        FontSize="14" Padding="0"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Margin="2,0,0,0"
                        ToolTip.Tip="New window" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Border>

        <Panel x:Name="WebViewContainer" />
    </DockPanel>
</Window>
